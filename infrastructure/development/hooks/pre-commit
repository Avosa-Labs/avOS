#!/usr/bin/env sh
# Refuses a commit that would introduce a convention violation, a brand leak, or
# a stand-in on a production path.
#
# These three checks are fast and catch what is expensive to remove from
# history. The full gate set runs separately; this hook is not a substitute.

set -eu

repository_root=$(git rev-parse --show-toplevel)
cd "$repository_root"

command -v zig >/dev/null 2>&1 || {
    printf 'pre-commit: zig is not on PATH; run tools/bootstrap/bootstrap.sh\n' >&2
    exit 1
}

zig build convention-check || {
    printf '\npre-commit: authoring conventions violated; commit refused\n' >&2
    exit 1
}

zig build brand-check || {
    printf '\npre-commit: product naming outside the brand layer; commit refused\n' >&2
    exit 1
}

zig build standin-check || {
    printf '\npre-commit: a stand-in reaches production code; commit refused\n' >&2
    exit 1
}
