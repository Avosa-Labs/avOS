#!/usr/bin/env sh
# Rejects a commit message that credits a tool or model as an author.
#
# The repository must read as the work of accountable engineers. An attribution
# trailer is permanent once it reaches history and removing it later means
# rewriting every commit after it, so the cheapest place to stop one is here.
#
# Install with: infrastructure/development/hooks/install.sh

set -eu

# Character ranges are collation-dependent: under a UTF-8 locale a range such
# as [A-Z] also matches most lowercase letters. Every comparison below is a
# byte comparison, so the locale is pinned rather than trusted.
LC_ALL=C
export LC_ALL

message_file=$1

# Trailers and notices that name a tool or model as an author. Matched without
# regard to case, because a trailer is a trailer however it is spelled.
prohibited='Co-Authored-By|Co-authored-by|Generated with \[|generated by AI|written by (ChatGPT|Claude|an AI)|Assisted-By|ChatGPT|OpenAI|Anthropic|Copilot'

if grep -qEi "$prohibited" "$message_file"; then
    printf 'commit-msg: the message credits a tool or model as an author\n\n' >&2
    grep -nEi "$prohibited" "$message_file" >&2
    printf '\nRemove the attribution and commit again.\n' >&2
    exit 1
fi

if grep -q '🤖' "$message_file"; then
    printf 'commit-msg: the message contains a tool signature\n' >&2
    exit 1
fi

# Subject line discipline: lowercase, imperative, concise, no period, no emoji.
subject=$(sed -n '1p' "$message_file")
case "$subject" in
    '#'*) exit 0 ;;  # A comment-only message is git's own abort path.
esac

if [ ${#subject} -gt 72 ]; then
    printf 'commit-msg: subject is %d characters; keep it under 72\n' "${#subject}" >&2
    exit 1
fi

case "$subject" in
    *.) printf 'commit-msg: subject must not end with a period\n' >&2; exit 1 ;;
esac

first_character=$(printf '%s' "$subject" | cut -c1)
case "$first_character" in
    [[:upper:]]) printf 'commit-msg: subject must be lowercase\n' >&2; exit 1 ;;
esac

exit 0
